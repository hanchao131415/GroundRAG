# ===== LLM（必填，二选一）=====
# DeepSeek 示例
LLM_PROVIDER=deepseek
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
# 或 智谱 GLM：
# LLM_PROVIDER=zhipu
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-4-flash

LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ===== 文档处理 =====
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=25

# ===== 检索 =====
RAG_VECTOR_K=15
RAG_BM25_K=15
RAG_TOP_K=3
RAG_RRF_K=60

# ===== JWT（生产必须改成随机长串）=====
JWT_SECRET=change-me-to-a-random-long-string
JWT_EXPIRE_HOURS=24

# ===== 可观测（可选，不配则只用本地 trace）=====
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
